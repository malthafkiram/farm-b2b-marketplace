<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Riwayat Transaksi</title>
<%- include('_style') %>
</head>

<body>
    <%- include('_navbar') %>
    <div class="container mt-5">

        <div
            class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
            <div>
                <h1 class="page-title">Riwayat Pembelian Ternak</h1>
            </div>
            <div>
                <a href="/" class="btn-neo-back">← Kembali ke Marketplace</a>
            </div>
        </div>

        <div class="table-responsive table-responsive-neo">
            <table class="table table-neo align-middle">
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">No.</th>
                        <th>Nomor Resi</th>
                        <th>Kode Ternak</th>
                        <th>Nama Hewan</th>
                        <th>Jenis</th>
                        <th>Total Bayar</th>
                        <th>Tanggal Transaksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (transactions.length===0) { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 fw-bold text-muted">
                                Anda belum pernah melakukan transaksi pembelian hewan ternak.
                            </td>
                        </tr>
                        <% } else { %>
                            <% transactions.forEach((tx, index)=> { %>
                                <tr>
                                    <td class="fw-bold text-center">
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <span class="neo-receipt-code">
                                            <%= tx.receiptNumber %>
                                        </span>
                                    </td>
                                    <td class="fw-bold">
                                        <%= tx.Livestock ? tx.Livestock.animalCode : '-' %>
                                    </td>
                                    <td class="fw-bold text-uppercase">
                                        <% if (tx.Livestock) { %>
                                            <%= tx.Livestock.name %>
                                                <% } else { %>
                                                    <span class="text-deleted-animal">Data Hewan Telah Dihapus</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= tx.Livestock ? tx.Livestock.type : '-' %>
                                    </td>
                                    <td class="fw-bold text-success" style="font-size: 1.05rem;">
                                        <%= formatRupiah(tx.totalPaid) %>
                                    </td>
                                    <td class="small fw-medium">
                                        <%= new Date(tx.createdAt).toLocaleDateString('id-ID', { weekday: 'long' ,
                                            year: 'numeric' , month: 'long' , day: 'numeric' , hour: '2-digit' ,
                                            minute:'2-digit' }) %> WIB
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } %>
                </tbody>
            </table>
        </div>

    </div>
    <%- include('_footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>