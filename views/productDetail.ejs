<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <%- include('_style') %>
  </head>
  <body>
    <%- include('_navbar') %>
    <div class="content">
      <div class="container">
        <!-- PRODUCT DETAIL CARD -->
        <div
          class="neo-card"
          style="display: flex; justify-content: space-evenly"
        >
          <!-- IMAGE -->
          <div>
            <img
              src="https://images.unsplash.com/photo-1548550023-2bdb3c5beed7"
              class="mt-4"
              style="
                height: 450px;
                object-fit: cover;
                border-right: 4px solid var(--dark-border);
              "
            />
          </div>

          <!-- INFO -->
          <div class="col-lg-6 p-4">
            <!-- CATEGORY -->
            <span class="animal-tag tag-yellow"> AYAM PEDAGING </span>

            <!-- NAME -->
            <h2 class="fw-bold mt-3">Ayam Broiler Premium</h2>

            <!-- DESCRIPTION -->
            <p class="text-muted">
              Ayam broiler berkualitas tinggi dengan perawatan modern farm.
              Cocok untuk usaha ternak skala kecil maupun besar.
            </p>

            <!-- PRICE -->
            <div class="price mb-3">Rp 120.000</div>

            <!-- INFO -->
            <div class="mb-2">
              <i class="bi bi-box"></i>
              Stok: 120 ekor
            </div>

            <div class="mb-2">
              <i class="bi bi-truck"></i>
              Pengiriman: 1 - 2 hari
            </div>

            <div class="mb-4">
              <i class="bi bi-shield-check"></i>
              Sehat & sudah vaksin
            </div>

            <!-- QTY -->
            <div class="d-flex align-items-center gap-3 mb-3">
              <button class="btn btn-outline-dark">-</button>
              <span class="fw-bold">1</span>
              <button class="btn btn-outline-dark">+</button>
            </div>

            <!-- ACTION -->
            <div class="d-grid gap-2">
              <a href="/cart" class="btn btn-buy">
                <i class="bi bi-cart3"></i> BELI SEKARANG
              </a>
            </div>
          </div>
        </div>

        <!-- DETAIL SECTION -->
        <div class="neo-card mt-4 p-4">
          <h4 class="fw-bold">Detail Produk</h4>

          <p>
            Ayam broiler ini dipelihara dengan standar peternakan modern
            menggunakan pakan berkualitas tinggi dan kontrol kesehatan rutin.
            Cocok untuk kebutuhan restoran, reseller, maupun konsumsi pribadi.
          </p>

          <ul>
            <li>Berat rata-rata: 1.5 - 2 kg</li>
            <li>Umur panen: 30 - 35 hari</li>
            <li>Pakan berkualitas premium</li>
            <li>Diproses higienis</li>
          </ul>
        </div>

        <!-- RELATED PRODUCTS -->
        <div class="mt-4">
          <h4 class="fw-bold mb-3">Produk Serupa</h4>

          <div class="row g-4">
            <!-- CARD 1 -->
            <div class="col-lg-4">
              <div class="neo-card p-3">
                <img
                  src="https://images.unsplash.com/photo-1516467508483-a7212febe31a"
                  style="
                    height: 200px;
                    width: 100%;
                    object-fit: cover;
                    border: 3px solid var(--dark-border);
                  "
                />

                <h5 class="mt-3 fw-bold">Kambing Etawa</h5>
                <div class="price">Rp 2.500.000</div>
              </div>
            </div>

            <!-- CARD 2 -->
            <div class="col-lg-4">
              <div class="neo-card p-3">
                <img
                  src="https://images.unsplash.com/photo-1500595046743-cd271d694d30"
                  style="
                    height: 200px;
                    width: 100%;
                    object-fit: cover;
                    border: 3px solid var(--dark-border);
                  "
                />

                <h5 class="mt-3 fw-bold">Sapi Limousin</h5>
                <div class="price">Rp 18.000.000</div>
              </div>
            </div>

            <!-- CARD 3 -->
            <div class="col-lg-4">
              <div class="neo-card p-3">
                <img
                  src="https://images.unsplash.com/photo-1517849845537-4d257902454a"
                  style="
                    height: 200px;
                    width: 100%;
                    object-fit: cover;
                    border: 3px solid var(--dark-border);
                  "
                />

                <h5 class="mt-3 fw-bold">Bebek Petelur</h5>
                <div class="price">Rp 350.000</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
