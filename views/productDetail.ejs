<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= product.name %></title>
    <%- include('_style') %>
  </head>

  <body>
    <%- include('_navbar') %>

    <div class="content">
      <div class="container">

        <% let tagClass = ''; %>

        <% if (product.type === 'Domba') { %>
          <% tagClass = 'tag-yellow' %>
        <% } else if (product.type === 'Sapi') { %>
          <% tagClass = 'tag-pink' %>
        <% } else { %>
          <% tagClass = 'tag-blue' %>
        <% } %>

        <!-- PRODUCT DETAIL -->
        <div
          class="neo-card"
          style="display: flex; justify-content: space-evenly"
        >

          <!-- IMAGE -->
          <div>
            <img
              src="<%= product.imageUrl %>"
              class="my-4"
              style="
                height: 450px;
                width: 450px;
                object-fit: cover;
                border-right: 4px solid var(--dark-border);
              "
            />
          </div>

          <!-- INFO -->
          <div class="col-lg-6 p-4">

            <!-- CATEGORY -->
            <span class="animal-tag <%= tagClass %>">
              <%= product.type %>
            </span>

            <!-- NAME -->
            <h2 class="fw-bold mt-3">
              <%= product.name %>
            </h2>

            <!-- DESCRIPTION -->
            <p class="text-muted">
              <%= product.description %>
            </p>

            <!-- PRICE -->
            <div class="price mb-3">
              <%= formatRupiah(product.price) %>
            </div>

            <!-- INFO -->
            <div class="mb-2">
              <i class="bi bi-gender-ambiguous"></i>
              Gender: <%= product.gender %>
            </div>

            <div class="mb-2">
              <i class="bi bi-person"></i>
              Penjual:
              <%= product.User.UserProfile.fullName %>
            </div>

            <div class="mb-2">
              <i class="bi bi-geo-alt"></i>
              Lokasi:
              <%= product.User.UserProfile.address || 'Tidak tersedia' %>
            </div>

            <div class="mb-4">
              <i class="bi bi-check-circle"></i>
              Status:
              <%= product.status %>
            </div>

            <!-- ACTION -->
            <div class="d-grid gap-2">

              <% if (userRole === 'Buyer') { %>

                <a
                  href="/stock/buy/<%= product.id %>"
                  class="btn btn-buy"
                >
                  <i class="bi bi-cart3"></i>
                  BELI SEKARANG
                </a>

              <% } else if (!isLogin) { %>
                 <% if (product.status === 'Terjual') { %>
                    <a
                      href="/stock"
                      class="btn btn-buy"
                    >
                      LIHAT TERNAK LAINNYA
                    </a>

                  <% } else { %>
                    <a
                      href="/login"
                      class="btn btn-buy"
                    >
                      LOGIN UNTUK BELI
                    </a>
                  <% } %>

              <% } else if (userRole === 'Seller') { %>

                <a
                  href="/stock/edit/<%= product.id %>"
                  class="btn btn-buy"
                >
                  EDIT PRODUK
                </a>

              <% } %>

            </div>
          </div>
        </div>

        <!-- DETAIL SECTION -->
        <div class="neo-card mt-4 p-4">

          <h4 class="fw-bold">
            Detail Produk
          </h4>

          <p>
            <%= product.description %>
          </p>

          <ul>
            <li>Jenis ternak: <%= product.type %></li>
            <li>Gender: <%= product.gender %></li>
            <li>Penjual terpercaya dari <%= product.User.UserProfile.fullName %></li>
          </ul>

        </div>
      </div>
    </div>
    <%- include('_footer') %>
  </body>
</html>