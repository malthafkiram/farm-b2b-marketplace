<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Sayap Cinta Farm</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts: Space Grotesk -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #f4f1de;
            /* Warna koran mentah */
            --primary-yellow: #ffde4d;
            /* Kuning terang */
            --accent-blue: #3a86ff;
            /* Biru pop untuk variasi komponen */
            --accent-pink: #ff6b6b;
            /* Pink/Merah pop */
            --dark-border: #1a1a1a;
            /* Border hitam pekat */
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Space Grotesk', sans-serif;
            padding: 20px;
        }

        /* --- NEOBRUTALISM FORM CARD --- */
        .neo-card {
            background-color: #ffffff;
            border: 4px solid var(--dark-border);
            box-shadow: 12px 12px 0px 0px var(--dark-border);
            border-radius: 0px;
            padding: 40px;
            margin-top: 50px;
            margin-bottom: 50px;

            /* Animasi Pop-Up Masuk saat Page Load */
            opacity: 0;
            transform: scale(0.9) translateY(30px);
            animation: popUpIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.2s forwards;
        }

        .form-title {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 2rem;
            letter-spacing: -1px;
            display: inline-block;
            background-color: var(--accent-pink);
            padding: 5px 15px;
            border: 3px solid var(--dark-border);
            box-shadow: 4px 4px 0px var(--dark-border);
            transform: rotate(-1deg);
            margin-bottom: 30px;
        }

        /* --- FORM INPUTS STYLE --- */
        .neo-label {
            font-weight: 700;
            text-transform: uppercase;
            color: var(--dark-border);
            margin-bottom: 8px;
            display: block;
        }

        .neo-input {
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 12px 15px;
            font-weight: 500;
            background-color: #ffffff;
            color: var(--dark-border);
            transition: all 0.15s ease;
        }

        /* Efek fokus input yang nabrak/kontras */
        .neo-input:focus {
            outline: none !important;
            box-shadow: 4px 4px 0px 0px var(--dark-border) !important;
            background-color: var(--primary-yellow);
            transform: translate(-2px, -2px);
        }

        /* Style khusus untuk Select/Dropdown */
        .neo-select {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='%231a1a1a' stroke-width='3' stroke-linecap='square' stroke-linejoin='miter'><path d='M6 9l6 6 6-6'/></svg>");
            background-repeat: no-repeat;
            background-position: right 15px center;
            cursor: pointer;
        }

        /* --- BUTTON STYLE --- */
        .btn-neo-submit {
            width: 100%;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 1.2rem;
            background-color: var(--primary-yellow);
            color: var(--dark-border);
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 12px !important;
            box-shadow: 6px 6px 0px var(--dark-border);
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-neo-submit:hover {
            background-color: var(--accent-blue);
            color: #ffffff;
            transform: translate(-3px, -3px);
            box-shadow: 9px 9px 0px var(--dark-border);
        }

        .btn-neo-submit:active {
            transform: translate(6px, 6px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* Teks link di bawah form */
        .form-footer-link {
            color: var(--dark-border);
            font-weight: 700;
            text-decoration: underline;
        }

        .form-footer-link:hover {
            color: var(--accent-pink);
        }

        /* --- KEYFRAMES ANIMATION --- */
        @keyframes popUpIn {
            0% {
                opacity: 0;
                transform: scale(0.9) translateY(30px);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
    </style>
    <%- include('_style') %>
</head>

<body>
    <!-- NAVBAR -->
    <%- include('_navbar') %>
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-7 col-lg-6">

                    <!-- Register Card Start -->
                    <div class="card neo-card">

                        <!-- Judul Form bergaya Brutalisme -->
                        <div class="text-center">
                            <h2 class="form-title">Daftar Akun Baru</h2>
                        </div>

                        <form action="/register" method="POST">

                            <!-- Full Name -->
                            <div class="mb-4">
                                <label for="fullName" class="neo-label">Nama Lengkap</label>
                                <input type="text" id="fullName" class="form-control neo-input"
                                    placeholder="Masukkan nama lengkap" name="fullName" required>
                            </div>

                            <!-- Email -->
                            <div class="mb-4">
                                <label for="email" class="neo-label">Alamat Email</label>
                                <input type="email" id="email" class="form-control neo-input"
                                    placeholder="contoh@email.com" name="email" required>
                            </div>

                            <!-- Phone Number -->
                            <div class="mb-4">
                                <label for="phoneNumber" class="neo-label">Nomor WhatsApp / HP</label>
                                <input type="tel" id="phoneNumber" class="form-control neo-input"
                                    placeholder="08xxxxxxxxxx" name="phoneNumber" required>
                            </div>

                            <!-- Role (Dropdown) -->
                            <div class="mb-4">
                                <label for="role" class="neo-label">Pilih Peran (Role)</label>
                                <select id="role" class="form-select neo-input neo-select" name="role" required>
                                    <option value="" disabled selected hidden>Pilih peran kamu...</option>
                                    <option value="Buyer">Buyer (Pembeli Ternak)</option>
                                    <option value="Seller">Seller (Peternak / Penjual)</option>
                                </select>
                            </div>

                            <!-- Password -->
                            <div class="mb-5">
                                <label for="password" class="neo-label">Password</label>
                                <input type="password" id="password" class="form-control neo-input"
                                    placeholder="Buat password aman" name="password" required>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-neo-submit mb-3">Gabung Sekarang</button>

                            <!-- Footer Form -->
                            <div class="text-center mt-4">
                                <p class="mb-0 fw-medium">Sudah punya akun? <a href="/login"
                                        class="form-footer-link">Login
                                        di
                                        sini</a></p>
                            </div>

                        </form>
                    </div>
                    <!-- Register Card End -->

                </div>
            </div>
        </div>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>