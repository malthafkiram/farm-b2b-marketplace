<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cart - Sayap Cinta Farm</title>

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />

    <!-- Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f4f1de;
        --border: #1a1a1a;
        --yellow: #ffde4d;
        --pink: #ff6b6b;
      }

      body {
        background: var(--bg);
        font-family: "Space Grotesk", sans-serif;
      }

      .neo-box {
        border: 4px solid var(--border);
        background: white;
        box-shadow: 8px 8px 0 var(--border);
      }

      .cart-item {
        border-bottom: 3px solid var(--border);
        padding: 15px 0;
      }

      .cart-img {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border: 3px solid var(--border);
      }

      .qty-box {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .qty-btn {
        border: 3px solid var(--border);
        background: var(--yellow);
        width: 30px;
        height: 30px;
        font-weight: bold;
      }

      .checkout-btn {
        width: 100%;
        padding: 12px;
        border: 3px solid var(--border);
        background: var(--yellow);
        font-weight: 700;
        box-shadow: 6px 6px 0 var(--border);
      }

      .checkout-btn:hover {
        background: var(--pink);
        transform: translate(-2px, -2px);
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <!-- TITLE -->
      <div class="neo-box p-3 mb-4 text-center">
        <h2 class="fw-bold m-0">🛒 Cart</h2>
      </div>

      <div class="row g-4">
        <!-- LEFT: CART ITEMS -->
        <div class="col-lg-8">
          <div class="neo-box p-4">
            <!-- ITEM 1 -->
            <div
              class="d-flex cart-item align-items-center justify-content-between"
            >
              <div class="d-flex align-items-center gap-3">
                <img
                  src="https://images.unsplash.com/photo-1548550023-2bdb3c5beed7"
                  class="cart-img"
                />

                <div>
                  <h5 class="m-0 fw-bold">Ayam Broiler</h5>
                  <small>Rp 120.000</small>
                </div>
              </div>

              <div class="qty-box">
                <button class="qty-btn">-</button>
                <span>1</span>
                <button class="qty-btn">+</button>
              </div>

              <strong>Rp 120.000</strong>
            </div>

            <!-- ITEM 2 -->
            <div
              class="d-flex cart-item align-items-center justify-content-between"
            >
              <div class="d-flex align-items-center gap-3">
                <img
                  src="https://images.unsplash.com/photo-1516467508483-a7212febe31a"
                  class="cart-img"
                />

                <div>
                  <h5 class="m-0 fw-bold">Kambing Etawa</h5>
                  <small>Rp 2.500.000</small>
                </div>
              </div>

              <div class="qty-box">
                <button class="qty-btn">-</button>
                <span>1</span>
                <button class="qty-btn">+</button>
              </div>

              <strong>Rp 2.500.000</strong>
            </div>
          </div>
        </div>

        <!-- RIGHT: SUMMARY -->
        <div class="col-lg-4">
          <div class="neo-box p-4">
            <h4 class="fw-bold mb-3">Ringkasan</h4>

            <div class="d-flex justify-content-between mb-2">
              <span>Subtotal</span>
              <strong>Rp 2.620.000</strong>
            </div>

            <div class="d-flex justify-content-between mb-3">
              <span>Ongkir</span>
              <strong>Rp 20.000</strong>
            </div>

            <hr />

            <div class="d-flex justify-content-between mb-3">
              <h5>Total</h5>
              <h5 class="fw-bold">Rp 2.640.000</h5>
            </div>

            <button class="checkout-btn">CHECKOUT</button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
