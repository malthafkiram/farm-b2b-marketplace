<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sayap Cinta Farm - Dashboard Peternak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #f4f1de;
            /* Warna koran mentah */
            --primary-yellow: #ffde4d;
            /* Kuning terang */
            --accent-blue: #3a86ff;
            /* Biru pop */
            --accent-pink: #ff6b6b;
            /* Pink pop */
            --accent-green: #2ec4b6;
            /* Hijau neon */
            --dark-border: #1a1a1a;
            /* Border hitam pekat */
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Space Grotesk', sans-serif;
            padding-bottom: 50px;
        }

        /* --- TITLE STYLE --- */
        .page-title {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 2rem;
            letter-spacing: -1px;
            display: inline-block;
            background-color: var(--accent-blue);
            /* Aksen biru pop untuk dashboard seller */
            color: #ffffff;
            padding: 8px 20px;
            border: 4px solid var(--dark-border);
            box-shadow: 6px 6px 0px var(--dark-border);
            transform: rotate(0.5deg);
            margin-bottom: 30px;
        }

        /* --- BUTTONS STYLE --- */
        .btn-neo-back {
            font-weight: 700;
            text-transform: uppercase;
            background-color: #ffffff;
            color: var(--dark-border) !important;
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 10px 20px;
            box-shadow: 4px 4px 0px var(--dark-border);
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none;
            display: inline-block;
        }

        .btn-neo-back:hover {
            background-color: var(--primary-yellow);
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--dark-border);
        }

        .btn-neo-back:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* --- TABLE NEORUTALISM STYLE --- */
        .table-responsive-neo {
            background-color: #ffffff;
            border: 4px solid var(--dark-border);
            box-shadow: 12px 12px 0px var(--dark-border);
            margin-top: 20px;

            /* Animasi Fade In Pop */
            opacity: 0;
            transform: translateY(20px);
            animation: tablePopUp 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        .table-neo {
            margin-bottom: 0px !important;
        }

        .table-neo thead th {
            background-color: var(--primary-yellow) !important;
            color: var(--dark-border) !important;
            font-weight: 700;
            text-transform: uppercase;
            border-bottom: 4px solid var(--dark-border) !important;
            border-right: 2px solid var(--dark-border);
            padding: 15px;
        }

        .table-neo tbody td {
            border-bottom: 3px solid var(--dark-border) !important;
            border-right: 2px solid var(--dark-border);
            padding: 15px;
            font-weight: 500;
            vertical-align: middle;
            color: var(--dark-border);
        }

        .table-neo tbody tr:last-child td {
            border-bottom: none !important;
        }

        .table-neo tbody tr:hover {
            background-color: rgba(58, 134, 255, 0.08);
            /* Highlight baris bertema biru */
        }

        /* Code Block Brutal */
        .neo-code {
            font-family: 'Space Grotesk', monospace;
            background-color: var(--dark-border);
            color: #ffffff;
            font-weight: 700;
            padding: 3px 8px;
            border: 1px solid var(--dark-border);
        }

        /* Badge Status Neobrutal */
        .badge-status-neo {
            display: inline-block;
            padding: 6px 12px;
            border: 2px solid var(--dark-border);
            font-weight: 700;
            text-transform: uppercase;
            box-shadow: 2px 2px 0px var(--dark-border);
        }

        .status-available {
            background-color: #a7c957;
            color: var(--dark-border);
        }

        .status-sold {
            background-color: var(--accent-pink);
            color: #ffffff;
        }

        /* Kotak Info Transaksi */
        .transaction-info-box {
            padding: 8px 12px;
            border: 2px dashed var(--dark-border);
            background-color: #fafafa;
        }

        .text-no-tx {
            color: #777777;
            font-style: italic;
        }

        /* --- KEYFRAMES ANIMATION --- */
        @keyframes tablePopUp {
            0% {
                opacity: 0;
                transform: translateY(20px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="container mt-5">

        <div
            class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
            <div>
                <h1 class="page-title">Dashboard Monitoring Ternak</h1>
            </div>
            <div>
                <a href="/stock" class="btn-neo-back">← Kembali ke Marketplace</a>
            </div>
        </div>

        <div class="table-responsive table-responsive-neo">
            <table class="table table-neo align-middle">
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">No.</th>
                        <th>Kode Ternak</th>
                        <th>Nama Hewan</th>
                        <th>Jenis</th>
                        <th>Harga Jual</th>
                        <th>Status Kandang</th>
                        <th>Informasi Pembeli / Transaksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (myStocks.length===0) { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 fw-bold text-muted">
                                Anda belum mendaftarkan hewan ternak apa pun di marketplace ini.
                            </td>
                        </tr>
                        <% } else { %>
                            <% myStocks.forEach((stock, index)=> { %>
                                <tr>
                                    <td class="fw-bold text-center">
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <span class="neo-code">
                                            <%= stock.animalCode %>
                                        </span>
                                    </td>
                                    <td class="fw-bold text-uppercase">
                                        <%= stock.name %>
                                    </td>
                                    <td>
                                        <%= stock.type %>
                                    </td>
                                    <td class="fw-bold text-success">
                                        <%= formatRupiah(stock.price) %>
                                    </td>
                                    <td>
                                        <% if (stock.status==='Tersedia' ) { %>
                                            <span class="badge-status-neo status-available">
                                                <%= stock.status %>
                                            </span>
                                            <% } else { %>
                                                <span class="badge-status-neo status-sold">
                                                    <%= stock.status %>
                                                </span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <% if (stock.Transactions && stock.Transactions.length> 0) { %>
                                            <% const tx=stock.Transactions[0]; %>
                                                <div class="transaction-info-box">
                                                    <div class="fw-bold text-uppercase" style="font-size: 0.9rem;">
                                                        Pembeli: <span class="text-primary">
                                                            <%= tx.User && tx.User.UserProfile ?
                                                                tx.User.UserProfile.fullName : 'User Anonim' %>
                                                        </span>
                                                    </div>
                                                    <div class="text-muted small mt-1" style="font-family: monospace;">
                                                        Resi: <%= tx.receiptNumber %>
                                                    </div>
                                                </div>
                                                <% } else { %>
                                                    <span class="text-no-tx">Belum ada penawaran / transaksi</span>
                                                    <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>