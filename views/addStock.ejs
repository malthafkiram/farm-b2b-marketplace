<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Tambah Ternak</title>
   <%- include('_style') %>    <style>
        /* --- KEYFRAMES ANIMATION --- */
        @keyframes formPopIn {
            0% {
                opacity: 0;
                transform: scale(0.95) translateY(20px);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
    </style>
    
</head>

<body>

    <%- include('_navbar') %>
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">

                    <div class="card neo-form-card">

                        <div class="text-center">
                            <h2 class="form-title">Tambah Hewan Ternak Baru</h2>
                        </div>

                        <% if (errors) { %>
                            <div class="neo-error-box">
                                <h4>Gagal Menambahkan Data:</h4>
                                <ul>
                                    <% JSON.parse(errors).forEach(err=> { %>
                                        <li>
                                            <%= err %>
                                        </li>
                                        <% }) %>
                                </ul>
                            </div>
                            <% } %>

                                <form action="/stock/add" method="POST" enctype="multipart/form-data">

                                    <div class="mb-4">
                                        <label class="neo-label">Nama Ternak / Label:</label>
                                        <input type="text" name="name" class="form-control neo-input"
                                            placeholder="Contoh: Sapi Limousin Jumbo">
                                    </div>

                                    <div class="mb-4">
                                        <label class="neo-label">Jenis Hewan:</label>
                                        <select name="type" class="form-select neo-input neo-select">
                                            <option value="">-- Pilih Jenis --</option>
                                            <option value="Sapi">Sapi</option>
                                            <option value="Kambing">Kambing</option>
                                            <option value="Domba">Domba</option>
                                        </select>
                                    </div>

                                    <div class="mb-4">
                                        <label class="neo-label">Jenis Kelamin:</label>
                                        <div class="neo-radio-wrapper">
                                            <label class="neo-radio-label">
                                                <input type="radio" name="gender" value="Jantan" class="neo-radio"
                                                    checked>
                                                Jantan
                                            </label>
                                            <label class="neo-radio-label">
                                                <input type="radio" name="gender" value="Betina" class="neo-radio">
                                                Betina
                                            </label>
                                        </div>
                                    </div>

                                    <div class="mb-5">
                                        <label class="neo-label">Harga Jual (Minimal Rp 500.000):</label>
                                        <div class="input-group">
                                            <span class="input-group-text neo-input-group-text">Rp</span>
                                            <input type="number" name="price" class="form-control neo-input"
                                                placeholder="Contoh: 15000000">
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="neo-label">Deskripsi / Catatan Kondisi:</label>
                                        <textarea name="description"
                                            class="form-control neo-input neo-textarea"></textarea>
                                    </div>

                                    <div class="mb-5">
                                        <label class="neo-label">Foto Fisik Hewan Ternak:</label>
                                        <div class="neo-file-upload-wrapper">

                                            <span class="neo-file-upload-text" id="file-label-text">Upload Foto Ternak
                                                Anda</span>


                                            <!-- Input file asli tetap berfungsi di latar belakang -->
                                            <input type="file" name="image" id="neo-image-input"
                                                class="neo-file-input-hidden" accept="image/*" required>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-end">
                                        <a href="/stock" class="btn btn-neo-group btn-neo-cancel order-2 order-sm-1">←
                                            Kembali ke Daftar Stok</a>
                                        <button type="submit"
                                            class="btn btn-neo-group btn-neo-save order-1 order-sm-2">Simpan ke
                                            Kandang</button>
                                    </div>

                                </form>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>