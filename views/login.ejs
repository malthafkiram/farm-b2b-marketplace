<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <!-- Bootstrap 5 CSS -->
    <%- include('_style') %>
    <style>
      @keyframes popUpIn {
        0% {
          opacity: 0;
          transform: scale(0.9) translateY(30px);
        }

        100% {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }
    </style>
  </head>

  <body>
    <!-- NAVBAR -->
    <%- include('_navbar') %>

    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
          <!-- Login Card Start -->
          <div class="card neo-login-card">
            <!-- Judul Form -->
            <div class="text-center">
              <h2 class="login-title">Masuk Akun</h2>
            </div>
            <% if (notification) { %>
              <div
                style="background-color: #f8d7da; color: #721c24; padding: 12px; border: 1px solid #f5c6cb; border-radius: 5px; margin-bottom: 15px; width: fit-content; font-weight: bold;">
                ✗ <%= notification %>
              </div>
            <% } %>
            <form action="/login" method="POST">
              <!-- Email -->
              <div class="mb-4">
                <label for="email" class="neo-label">Alamat Email</label>
                <input
                  type="email"
                  id="email"
                  class="form-control neo-input"
                  placeholder="contoh@email.com"
                  name="email"
                  required
                />
              </div>

              <!-- Password -->
              <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                  <label for="password" class="neo-label">Password</label>
                  <a href="#" class="form-footer-link mb-2 small"
                    >Lupa Password?</a
                  >
                </div>
                <input
                  type="password"
                  id="password"
                  class="form-control neo-input"
                  placeholder="Masukkan password"
                  name="password"
                  required
                />
              </div>

              <!-- Remember Me -->
              <div class="mb-5 form-check d-flex align-items-center gap-2 ps-0">
                <input
                  type="checkbox"
                  class="form-check-input neo-checkbox m-0"
                  id="rememberMe"
                  style="width: 20px; height: 20px"
                />
                <label
                  class="form-check-label fw-bold text-uppercase small pt-1"
                  style="cursor: pointer"
                  for="rememberMe"
                  >Ingat Saya</label
                >
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-neo-login-submit mb-3">
                Masuk Sekarang
              </button>

              <!-- Footer Form -->
              <div class="text-center mt-4">
                <p class="mb-0 fw-medium">
                  Belum punya akun?
                  <a href="/register" class="form-footer-link"
                    >Daftar di sini</a
                  >
                </p>
              </div>
            </form>
          </div>
          <!-- Login Card End -->
        </div>
      </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <%- include('_footer') %>
  </body>
</html>
