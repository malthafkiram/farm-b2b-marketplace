<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sayap Cinta Farm</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts: Space Grotesk -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #f4f1de;
            /* Warna koran mentah */
            --primary-yellow: #ffde4d;
            /* Kuning terang */
            --accent-green: #2ec4b6;
            /* Hijau neon pop khusus untuk variasi Login */
            --accent-pink: #ff6b6b;
            /* Pink/Merah pop */
            --dark-border: #1a1a1a;
            /* Border hitam pekat */
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Space Grotesk', sans-serif;
            padding: 20px;
        }

        /* --- NEOBRUTALISM LOGIN CARD --- */
        .neo-login-card {
            background-color: #ffffff;
            border: 4px solid var(--dark-border);
            box-shadow: 12px 12px 0px 0px var(--dark-border);
            border-radius: 0px;
            padding: 40px;
            margin-top: 60px;
            margin-bottom: 50px;

            /* Animasi Pop-Up Masuk saat Page Load (Sama seperti Register) */
            opacity: 0;
            transform: scale(0.9) translateY(30px);
            animation: popUpIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.1s forwards;
        }

        .login-title {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 2rem;
            letter-spacing: -1px;
            display: inline-block;
            background-color: var(--accent-green);
            /* Variasi warna hijau pop untuk membedakan dari Register */
            padding: 5px 20px;
            border: 3px solid var(--dark-border);
            box-shadow: 4px 4px 0px var(--dark-border);
            transform: rotate(1deg);
            /* Miring ke arah berlawanan dari Register */
            margin-bottom: 30px;
        }

        /* --- FORM INPUTS STYLE --- */
        .neo-label {
            font-weight: 700;
            text-transform: uppercase;
            color: var(--dark-border);
            margin-bottom: 8px;
            display: block;
        }

        .neo-input {
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 12px 15px;
            font-weight: 500;
            background-color: #ffffff;
            color: var(--dark-border);
            transition: all 0.15s ease;
        }

        /* Efek fokus input khas Neobrutalisme */
        .neo-input:focus {
            outline: none !important;
            box-shadow: 4px 4px 0px 0px var(--dark-border) !important;
            background-color: var(--primary-yellow);
            transform: translate(-2px, -2px);
        }

        /* Checkbox Kustom */
        .neo-checkbox {
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            cursor: pointer;
        }

        .neo-checkbox:checked {
            background-color: var(--accent-pink) !important;
            border-color: var(--dark-border) !important;
        }

        /* --- BUTTON STYLE --- */
        .btn-neo-login-submit {
            width: 100%;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 1.2rem;
            background-color: var(--primary-yellow);
            color: var(--dark-border);
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 12px !important;
            box-shadow: 6px 6px 0px var(--dark-border);
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-neo-login-submit:hover {
            background-color: var(--accent-pink);
            color: #ffffff;
            transform: translate(-3px, -3px);
            box-shadow: 9px 9px 0px var(--dark-border);
        }

        .btn-neo-login-submit:active {
            transform: translate(6px, 6px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* Teks link di bawah form */
        .form-footer-link {
            color: var(--dark-border);
            font-weight: 700;
            text-decoration: underline;
        }

        .form-footer-link:hover {
            color: var(--accent-pink);
        }

        /* --- KEYFRAMES ANIMATION --- */
        @keyframes popUpIn {
            0% {
                opacity: 0;
                transform: scale(0.9) translateY(30px);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
    </style>
    <%- include('_style') %>
</head>

<body>
    <!-- NAVBAR -->
    <%- include('_navbar') %>

        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5">

                    <!-- Login Card Start -->
                    <div class="card neo-login-card">

                        <!-- Judul Form -->
                        <div class="text-center">
                            <h2 class="login-title">Masuk Akun</h2>
                        </div>

                        <form action="/login" method="POST">

                            <!-- Email -->
                            <div class="mb-4">
                                <label for="email" class="neo-label">Alamat Email</label>
                                <input type="email" id="email" class="form-control neo-input"
                                    placeholder="contoh@email.com" name="email" required>
                            </div>

                            <!-- Password -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <label for="password" class="neo-label">Password</label>
                                    <a href="#" class="form-footer-link mb-2 small">Lupa Password?</a>
                                </div>
                                <input type="password" id="password" class="form-control neo-input"
                                    placeholder="Masukkan password" name="password" required>
                            </div>

                            <!-- Remember Me -->
                            <div class="mb-5 form-check d-flex align-items-center gap-2 ps-0">
                                <input type="checkbox" class="form-check-input neo-checkbox m-0" id="rememberMe"
                                    style="width: 20px; height: 20px;">
                                <label class="form-check-label fw-bold text-uppercase small pt-1"
                                    style="cursor: pointer;" for="rememberMe">Ingat Saya</label>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-neo-login-submit mb-3">Masuk Sekarang</button>

                            <!-- Footer Form -->
                            <div class="text-center mt-4">
                                <p class="mb-0 fw-medium">Belum punya akun? <a href="/register"
                                        class="form-footer-link">Daftar di
                                        sini</a></p>
                            </div>

                        </form>
                    </div>
                    <!-- Login Card End -->

                </div>
            </div>
        </div>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>